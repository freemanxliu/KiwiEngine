        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;KiwiEngine Shader Compilation Pipeline&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- Row 1: DX11 — FXC only (DXC does not support SM 5.x)            -->
        <!-- ================================================================ -->
        <mxCell id="r1_label" value="&lt;b&gt;DX11&lt;/b&gt;" style="text;html=1;align=right;fontSize=16;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="10" y="105" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="d11_hlsl" value="&lt;b&gt;HLSL 源码&lt;/b&gt;&lt;br&gt;(.hlsl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="90" width="150" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="d11_fxc" value="&lt;b&gt;FXC 编译器&lt;/b&gt;&lt;br&gt;D3DCompile()&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;d3dcompiler.dll&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="85" width="170" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="d11_note" value="&lt;font color=&quot;#CC0000&quot;&gt;DXC 不支持 SM 5.x&lt;br&gt;DX11 只能用 FXC&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="345" y="148" width="130" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="d11_dxbc" value="&lt;b&gt;DXBC&lt;/b&gt;&lt;br&gt;ID3DBlob&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;SM 5.0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="90" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="d11_cso" value="&lt;font color=&quot;#888&quot;&gt;可离线预编译 .cso&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="585" y="143" width="110" height="16" as="geometry"/>
        </mxCell>

        <mxCell id="d11_create" value="&lt;b&gt;Create*Shader()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;独立 VS/PS API 对象&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="790" y="90" width="170" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="d11_bind" value="&lt;b&gt;VSSetShader()&lt;br&gt;PSSetShader()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;逐帧分别绑定&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1040" y="85" width="150" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="d11_gpu" value="&lt;b&gt;GPU ISA&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#fff&quot;&gt;驱动翻译 DXBC→原生指令&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6B6B;strokeColor=#CC0000;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1270" y="90" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- DX11 edges -->
