          <mxGeometry x="20" y="195" width="1470" height="1" as="geometry"/>
        </mxCell>

        <!-- ================================================================ -->
        <!-- Row 2: DX12 — DXC (SM 6.0 → DXIL) + FXC fallback (SM 5.0 → DXBC) -->
        <!-- ================================================================ -->
        <mxCell id="r2_label" value="&lt;b&gt;DX12&lt;/b&gt;" style="text;html=1;align=right;fontSize=16;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="10" y="310" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="d12_hlsl" value="&lt;b&gt;HLSL 源码&lt;/b&gt;&lt;br&gt;(.hlsl)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="295" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- Branch: DXC (Current) — top -->
        <mxCell id="d12_dxc" value="&lt;b&gt;DXC 编译器&lt;/b&gt;&lt;br&gt;IDxcCompiler3&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;dxcompiler.dll&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD700;strokeColor=#B8860B;" vertex="1" parent="1">
          <mxGeometry x="330" y="240" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d12_dxc_label" value="&lt;b&gt;Current&lt;/b&gt;" style="text;html=1;align=center;fontSize=10;fontColor=#B8860B;" vertex="1" parent="1">
          <mxGeometry x="375" y="222" width="55" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="d12_upgrade" value="&lt;font color=&quot;#0066CC&quot;&gt;自动升级 vs_5_0→vs_6_0&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="335" y="297" width="155" height="16" as="geometry"/>
        </mxCell>

        <!-- Branch: FXC fallback — bottom -->
        <mxCell id="d12_fxc" value="&lt;b&gt;FXC 编译器&lt;/b&gt;&lt;br&gt;D3DCompile()&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;d3dcompiler.dll&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="340" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d12_fxc_label" value="&lt;font color=&quot;#999&quot;&gt;Fallback (DXC 不可用时)&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="340" y="397" width="140" height="16" as="geometry"/>
        </mxCell>

        <!-- DXC → DXIL -->
        <mxCell id="d12_dxil" value="&lt;b&gt;DXIL&lt;/b&gt;&lt;br&gt;IDxcBlob&lt;br&gt;&lt;font color=&quot;#0066CC&quot;&gt;SM 6.0 (DXIL)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;" vertex="1" parent="1">
          <mxGeometry x="580" y="245" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="d12_dxil_note" value="&lt;font color=&quot;#888&quot;&gt;需 dxil.dll 签名验证&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="585" y="297" width="120" height="16" as="geometry"/>
        </mxCell>

        <!-- FXC → DXBC -->
        <mxCell id="d12_dxbc" value="&lt;b&gt;DXBC&lt;/b&gt;&lt;br&gt;ID3DBlob&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;SM 5.0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="345" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Both merge → store blob -->
        <mxCell id="d12_blob" value="&lt;b&gt;存 blob&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;DX12 无独立&lt;br&gt;VS/PS 对象&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="800" y="290" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="d12_pso" value="&lt;b&gt;CreateGraphics&lt;br&gt;PipelineState&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;VS+PS blob → PSO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1020" y="285" width="160" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="d12_bind" value="&lt;b&gt;SetPipelineState()&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;一步切换全部状态&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1260" y="290" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="d12_gpu" value="&lt;b&gt;GPU ISA&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#fff&quot;&gt;驱动翻译 DXIL/DXBC→原生指令&lt;br&gt;(CreatePSO 时完成)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6B6B;strokeColor=#CC0000;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1500" y="282" width="190" height="60" as="geometry"/>
        </mxCell>

