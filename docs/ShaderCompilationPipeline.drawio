        <mxCell id="gl_spirv" value="&lt;font color=&quot;#888&quot;&gt;可选: SPIR-V (GL_ARB_gl_spirv)&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
