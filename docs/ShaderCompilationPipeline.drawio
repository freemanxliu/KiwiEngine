        <mxCell id="gl_link" value="&lt;b&gt;glLinkProgram&lt;/b&gt;&lt;br&gt;VS + FS → Program&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;≈ DX12 PSO&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
